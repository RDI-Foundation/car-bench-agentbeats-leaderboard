{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "agent_json_output": {
        "type": "boolean",
        "default": false
      },
      "agent_model_name": {
        "type": "string",
        "default": "z-ai/glm-5"
      },
      "agent_openrouter_api_key": {
        "type": "string",
        "secret": true
      },
      "agent_openrouter_base_url": {
        "type": "string",
        "default": "https://openrouter.ai/api/v1"
      },
      "agent_reasoning_enabled": {
        "type": "boolean",
        "default": true
      },
      "agent_retrieval_enabled": {
        "type": "boolean",
        "default": false
      },
      "agent_tavily_api_key": {
        "type": "string",
        "secret": true,
        "default": ""
      },
      "agent_tools_enabled": {
        "type": "boolean",
        "default": false
      },
      "green_gemini_api_key": {
        "type": "string",
        "secret": true
      }
    },
    "required": [
      "green_gemini_api_key",
      "agent_openrouter_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "topic": "CAR-Bench evaluation tasks",
          "task_split": "test",
          "num_trials": 1,
          "tasks_base_num_tasks": -1,
          "tasks_hallucination_num_tasks": -1,
          "tasks_disambiguation_num_tasks": -1,
          "max_steps": 50
        },
        "participant_roles": {
          "green": "green",
          "purple1": "agent"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/car-bench-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "gemini_api_key": "${config.green_gemini_api_key}"
      }
    },
    "agent": {
      "manifest": "https://raw.githubusercontent.com/soumya-batra/agentswe-general/refs/heads/main/amber-manifest.json5",
      "config": {
        "json_output": "${config.agent_json_output}",
        "model_name": "${config.agent_model_name}",
        "openrouter_api_key": "${config.agent_openrouter_api_key}",
        "openrouter_base_url": "${config.agent_openrouter_base_url}",
        "reasoning_enabled": "${config.agent_reasoning_enabled}",
        "retrieval_enabled": "${config.agent_retrieval_enabled}",
        "tavily_api_key": "${config.agent_tavily_api_key}",
        "tools_enabled": "${config.agent_tools_enabled}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#agent.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019d017f-d87a-73b1-a654-1a001b574e92",
      "agent": "019e5cac-4e2a-7740-8e49-c234f149fe42"
    }
  }
}