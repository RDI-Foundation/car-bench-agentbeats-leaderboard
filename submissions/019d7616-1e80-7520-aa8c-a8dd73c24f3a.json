{
  "manifest_version": "0.1.0",
  "config_schema": {
    "type": "object",
    "properties": {
      "green_gemini_api_key": {
        "type": "string",
        "secret": true
      },
      "nathan_AGENT_LLM": {
        "type": "string"
      },
      "nathan_AGENT_TEMPERATURE": {
        "type": "number"
      },
      "nathan_AGENT_THINKING": {
        "type": "string"
      },
      "nathan_DASHSCOPE_API_KEY": {
        "type": "string"
      },
      "nathan_DASHSCOPE_BASE_URL": {
        "type": "string"
      },
      "nathan_GEMINI_API_KEY": {
        "type": "string"
      },
      "nathan_LOGURU_LEVEL": {
        "type": "string"
      }
    },
    "required": [
      "green_gemini_api_key"
    ],
    "additionalProperties": false
  },
  "components": {
    "gateway": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/agentbeats-gateway/refs/tags/v0.1/amber-manifest.json5",
      "config": {
        "assessment_config": {
          "topic": "CAR-Bench evaluation tasks",
          "task_split": "test",
          "num_trials": 1,
          "tasks_base_num_tasks": -1,
          "tasks_hallucination_num_tasks": -1,
          "tasks_disambiguation_num_tasks": -1,
          "max_steps": 50
        },
        "participant_roles": {
          "green": "green",
          "purple1": "nathan"
        },
        "callback_urls": {
          "green": "${bindings.green-proxy.url}"
        }
      }
    },
    "green": {
      "manifest": "https://raw.githubusercontent.com/RDI-Foundation/car-bench-agentbeats/refs/heads/main/amber/amber-manifest-green.json5",
      "config": {
        "gemini_api_key": "${config.green_gemini_api_key}"
      }
    },
    "nathan": {
      "manifest": "https://raw.githubusercontent.com/moimksa/Nathan_purple_agent/main/amber-manifest.json5",
      "config": {
        "AGENT_LLM": "${config.nathan_AGENT_LLM}",
        "AGENT_TEMPERATURE": "${config.nathan_AGENT_TEMPERATURE}",
        "AGENT_THINKING": "${config.nathan_AGENT_THINKING}",
        "DASHSCOPE_API_KEY": "${config.nathan_DASHSCOPE_API_KEY}",
        "DASHSCOPE_BASE_URL": "${config.nathan_DASHSCOPE_BASE_URL}",
        "GEMINI_API_KEY": "${config.nathan_GEMINI_API_KEY}",
        "LOGURU_LEVEL": "${config.nathan_LOGURU_LEVEL}"
      }
    }
  },
  "bindings": [
    {
      "to": "#gateway.green",
      "from": "#green.a2a"
    },
    {
      "to": "#gateway.purple1",
      "from": "#nathan.a2a"
    },
    {
      "to": "#green.proxy",
      "from": "#gateway.proxy",
      "weak": true,
      "name": "green-proxy"
    }
  ],
  "exports": {
    "results": "#gateway.results"
  },
  "metadata": {
    "agentbeats_ids": {
      "green": "019d017f-d87a-73b1-a654-1a001b574e92",
      "nathan": "019d7253-566d-7542-abd4-f78d146ca354"
    }
  }
}